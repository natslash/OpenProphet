# Alpaca API Configuration

# Gemini API (optional - for AI news cleaning)
GEMINI_API_KEY=your_gemini_api_key

# Agent Dashboard Configuration (optional)
AGENT_PORT=3737                        # Dashboard port (default: 3737)
AGENT_AUTH_TOKEN=                       # Set a token to require auth on all API routes
TRADING_BOT_PORT=4534                   # Go backend port (default: 4534)
TRADING_BOT_URL=http://localhost:4534   # Go backend URL (default: auto from port)

# IBKR (paper only until Phase 6 — 4002=paper, 4001=live/gated)
IBKR_HOST=127.0.0.1
IBKR_PORT=4002                          # paper only; 4001 (live) is human-gated to Phase 6
IBKR_CLIENT_ID=1

# Order kill-switch (Phase 4.3c). Master gate: when false, order intent is
# logged but nothing is placed/cancelled. Must be explicitly true to trade.
TRADING_ENABLED=false

# Supervised autonomous beat (Phase 4.3e). Disabled by default.
ADMIN_TOKEN=                            # bearer token for POST /api/v1/beat/authorize/:id; the Node agent must NOT have it. Empty = fail closed (no intent executes)
BEAT_ENABLED=false                      # start the beat loop (proposes intents only; never auto-executes)
BEAT_SYMBOL=ESTX50:20260619:C:6325      # configured target contract analysed each tick
BEAT_INTERVAL_SECS=300                  # tick cadence + intent TTL
BEAT_MAX_DAILY_EXECUTIONS=3             # hard cap on authorised executions/day
BEAT_FORCE_SIGNAL=false                 # testing aid: emit a buy signal every tick
