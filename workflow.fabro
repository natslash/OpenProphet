digraph G {
  graph [
    model_stylesheet="* { model: gemini-3.1-flash-lite; reasoning_effort: low; } .coding { model: gemini-3.1-pro-preview; reasoning_effort: high; } .review { model: claude-opus-4-8; reasoning_effort: high; }"
  ]

  start [shape=Mdiamond]
  exit [shape=Msquare]

  implement [shape=box, class="coding", label="Read the plan file referenced in the goal and implement every step. Follow CLAUDE.md and PROGRESS.md. One testable change. Add unit tests if applicable. **CRITICAL: If you must satisfy a Go interface but some methods are out of scope for the current phase, you MUST provide stub methods that return `fmt.Errorf(\"not implemented in this phase\")`.** If the task involves placing/cancelling live orders (port 4001), STOP and fail — that is out of scope and forbidden."]
  
  unit_test [shape=parallelogram, script="go test -race ./tws/... ./services/... 2>&1", goal_gate=true, max_retries=0]
  
  review [shape=box, class="review", label="Review the diff for protocol correctness, concurrency safety, and guardrail compliance. **CRITICAL: Approve stubbed interface methods (`not implemented`) if those methods are out of scope for the current phase.** Request changes if anything else is wrong; do not rubber-stamp."]
  
  integration_manual [shape=hexagon, label="integration_manual"]
  approve_push [shape=hexagon, label="approve_push"]
  
  push [shape=parallelogram, script="git push origin feature/ibkr-porting"]

  start -> implement
  
  implement -> unit_test
  
  // Gate 1: Unit tests
  // goal_gate=true ensures Fabro fails the workflow if tests fail,
  // returning control to the interactive REPL.
  unit_test -> review [condition="outcome=succeeded"]
  unit_test -> exit [condition="outcome!=succeeded"]
  
  // Gate 2: Code Review
  review -> integration_manual [label="pass"]
  review -> exit [label="fail"]
  
  integration_manual -> approve_push [label="pass"]
  approve_push -> push [label="A"]
  push -> exit
}
